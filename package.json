{
  "name": "sarrafak-web",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "npm run migrate && npm start",
    "migrate": "node --env-file-if-exists=.env scripts/migrate.js",
    "import:clients": "node --env-file-if-exists=.env scripts/import-clients.js",
    "create:client": "node --env-file-if-exists=.env scripts/create-client.js",
    "check": "node --check server.js && node --check app.js && node --check db.js && node --check security.js && node --check banking.js && node --check scripts/migrate.js && node --check scripts/import-clients.js && node --check scripts/create-client.js",
    "test": "node --test --test-isolation=none",
    "verify": "npm run check && npm test"
  },
  "dependencies": {
    "pg": "^8.16.3"
  }
}
