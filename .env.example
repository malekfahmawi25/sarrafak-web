NODE_ENV=development
PORT=4173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sarrafak
DATABASE_SSL=disable
APP_SECRET=replace-with-at-least-32-random-characters
PIN_PEPPER=replace-with-a-different-32-character-secret
ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
ALLOW_SELF_DEPOSIT=true
TRUST_PROXY=false
SESSION_TTL_HOURS=12
SESSION_IDLE_MINUTES=30
